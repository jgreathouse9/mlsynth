# hs_alpha_gibbs_cpp, sar_full_sampler_cpp_step2 from cmg777/starter-academic-v501).
# R 4.3.3, seed 20251022, step_rho 0.01, M=40000 burn=20000.
#
# California treated from 1988 (TREAT_YEAR); 38 donor states; 1970-2000.

BARE (p_factors=0, no covariate -- the identified spatial core):
  rho = 0.8492   att = -22.1047   n_active_alpha = 25

FULL (p_factors=1, X=retprice -- the tutorial's headline config):
  rho = 0.2069   CrI [0.1267, 0.2783]
  att = -16.4442 CrI [-16.7163, -16.1611]
  n_active_alpha = 25
  rho across seeds {20251022, 1, 7} = 0.2069, 0.2603, 0.2418

