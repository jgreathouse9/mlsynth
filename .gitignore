# Ignore build directories
build/
dist/

# Ignore egg-info
*.egg-info

*.tar.gz

# Ignore Python bytecode files
*.pyc
*.pyo

# Coverage files
.coverage
coverage.xml

# Personal Claude Code overrides (not team-shared)
.claude/settings.local.json

# Stray plot artifact emitted by some tests
y_lexplot.png

# on-demand reference clones (benchmarks)
benchmarks/reference/.cache/

# generated benchmark run outputs
benchmarks/REPORT.md
benchmarks/report.json

# local Quarto paper render artifacts (the tracked source lives on main as
# paper/paper.qmd; these are build outputs, mirroring paper/.gitignore there)
paper/.quarto/
paper/paper.tex
paper/paper.html
paper/paper_files/
paper/*.log
paper/jss.cls
paper/jss.bst
paper/jsslogo.jpg
